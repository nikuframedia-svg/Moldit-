# ── ProdPlan PP1 — Docker Environment Variables ──────────────────
# Copy this file to .env and adjust values as needed.
# Default values are used if variables are not set.

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=pp1
POSTGRES_PASSWORD=pp1secret
POSTGRES_DB=pp1
# POSTGRES_PORT=5432

# ── Backend ──────────────────────────────────────────────────────
ENVIRONMENT=production      # development | staging | production
DEBUG=false                 # true = enables /docs and /redoc
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json             # json | text
# CORS_ORIGINS=["http://localhost"]
# API_KEYS=[]               # Empty = dev mode (skip auth)
# NIKUFRA_DATA_DIR=data/nikufra
# BACKEND_PORT=8000

# ── Frontend ─────────────────────────────────────────────────────
# VITE_APP_MODE=api         # api | mock
# VITE_API_BASE_URL=/api
# FRONTEND_PORT=80
