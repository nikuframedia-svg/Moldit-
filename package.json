{
  "name": "prodplan-pp1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "turbo": "^2.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": "biome check --write",
    "*.py": [
      "uvx ruff check --fix --exit-zero",
      "uvx ruff format"
    ]
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
