{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://incompol.pt/schemas/audit_log/v1",
  "title": "Audit Log",
  "description": "Audit log entry para rastreabilidade (conforme C-15)",
  "type": "object",
  "required": ["audit_id", "actor", "action", "correlation_id", "timestamp"],
  "properties": {
    "audit_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID único do audit log entry"
    },
    "actor": {
      "type": "string",
      "description": "Actor (humano/serviço) que realizou a ação"
    },
    "action": {
      "type": "string",
      "description": "Ação realizada (ex: 'PR_APPROVED', 'SUGGESTION_ACCEPTED', 'PLAN_MERGED')"
    },
    "before": {
      "type": "object",
      "description": "Estado anterior (hash ou snapshot)",
      "properties": {
        "entity_type": { "type": "string" },
        "entity_id": { "type": "string" },
        "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "after": {
      "type": "object",
      "description": "Estado novo (hash ou snapshot)",
      "properties": {
        "entity_type": { "type": "string" },
        "entity_id": { "type": "string" },
        "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID de correlação do request"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp UTC da ação"
    },
    "entity_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entity_type": { "type": "string" },
          "entity_id": { "type": "string" }
        }
      },
      "description": "Referências a entidades relacionadas"
    },
    "metadata": {
      "type": "object",
      "description": "Metadados adicionais"
    }
  }
}
