{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://incompol.pt/schemas/suggestion/v1",
  "title": "Suggestion",
  "description": "Sugestão estruturada com outcomes",
  "type": "object",
  "required": ["suggestion_id", "type", "status", "created_from", "recommended_action_structured"],
  "properties": {
    "suggestion_id": {
      "type": "string",
      "format": "uuid"
    },
    "type": {
      "type": "string",
      "enum": [
        "CHANGE_TOOL_GROUPING",
        "ADD_OVERTIME",
        "MOVE_ORDER",
        "ADJUST_WEIGHTS",
        "REPLAN_ON_EVENT"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["OPEN", "ACCEPTED", "REJECTED"]
    },
    "created_from": {
      "type": "string",
      "description": "ID do scenario/plan/event que originou"
    },
    "recommended_action_structured": {
      "type": "object",
      "additionalProperties": true
    },
    "impact_case": {
      "type": "object",
      "properties": {
        "baseline_kpis": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "scenario_kpis": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "expected_value_eur": {
          "type": "number"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "impact_result": {
      "type": "object",
      "properties": {
        "measured_kpis": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "measured_value_eur": {
          "type": "number"
        },
        "method": {
          "type": "string",
          "enum": ["NAIVE_DIFFERENCE", "DiD", "MATCHED", "UNKNOWN"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "notes": { "type": "string" }
      }
    }
  }
}
