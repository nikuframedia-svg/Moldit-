{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://incompol.pt/schemas/pr/v1",
  "title": "Pull Request",
  "description": "PR para governar mudanças de plano",
  "type": "object",
  "required": [
    "pr_id",
    "status",
    "author",
    "baseline_plan_id",
    "candidate_plan_id",
    "approvals",
    "created_at"
  ],
  "properties": {
    "pr_id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "OPEN", "APPROVED", "MERGED", "ROLLED_BACK", "REJECTED"]
    },
    "author": {
      "type": "string"
    },
    "scenario_id": {
      "type": "string",
      "format": "uuid"
    },
    "baseline_plan_id": {
      "type": "string",
      "format": "uuid"
    },
    "candidate_plan_id": {
      "type": "string",
      "format": "uuid"
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["approver_id", "approved_at"],
        "properties": {
          "approver_id": { "type": "string" },
          "approved_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
