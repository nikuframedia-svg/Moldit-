FROM node:22-alpine

WORKDIR /app

# Install dependencies (incompol-plan tarball created by scripts/docker-build.sh)
COPY package.json package-lock.json ./
COPY incompol-plan-*.tgz ./
RUN TARBALL=$(ls incompol-plan-*.tgz 2>/dev/null || echo "") && \
    if [ -n "$TARBALL" ]; then \
      sed -i "s|\"file:../../INCOMPOL PLAN\"|\"file:./$TARBALL\"|" package.json; \
      rm -f package-lock.json; \
    fi && \
    npm install

# Copy source (will be overridden by volume mount)
COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
